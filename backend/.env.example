# Database Configuration
# For local development (SQLite):
DATABASE_URL=sqlite:///./data/pineview.db

# For production with Supabase (overrides SQLite):
# IMPORTANT: Use this exact format with ?sslmode=require at the end
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Supabase Configuration (required for production)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app

# Email Configuration (for password reset codes)
# In development, if these are not set, the reset code will be printed to the console
# For production, configure SMTP settings (Gmail example below)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_FROM_NAME=Pineview Maps
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# FRONTEND_URL=https://your-app.vercel.app